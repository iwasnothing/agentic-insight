# Custom OpenAI compatible endpoint configuration
CUSTOM_LLM_URL=http://localhost:8000/v1
CUSTOM_LLM_MODEL="/models/Qwen/Qwen3.6-35B-A3B-FP8"
CUSTOM_LLM_API_KEY=sk-dummy
GEMINI_API_KEY=sk-dummy

# API workflow paths and thresholds configuration
ONTOLOGY_FOLDER=./ontology
DATASET_FOLDER=./dataset
DOC_DB_PATH=./wiki.db
MAPPINGS_DB_PATH=./mappings.db
SEMANTIC_MAPPING_PATH=./mapping.yaml
OUTPUT_MD_PATH=./report.md

LINES_THRESHOLD=500
CONTEXT_SIZE_LIMIT=10000
TOP_N=100
ROW_LIMIT=100
MAX_SQL_ITERATIONS=5
MAX_ITERATIONS=10

# MCP Authentication Token
MCP_BEARER_TOKEN=my-secure-static-token-123

