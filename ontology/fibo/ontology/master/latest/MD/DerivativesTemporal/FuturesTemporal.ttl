# baseURI: https://spec.edmcouncil.org/fibo/ontology/master/latest/MD/DerivativesTemporal/FuturesTemporal/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/FinancialInstruments/InstrumentPricing/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/DatesAndTimes/FinancialDates/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/OwnershipAndControl/Ownership/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Relations/Relations/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/
# imports: https://www.omg.org/spec/Commons/AnnotationVocabulary/
# imports: https://www.omg.org/spec/Commons/DatesAndTimes/

@base <https://spec.edmcouncil.org/fibo/ontology/master/latest/MD/DerivativesTemporal/FuturesTemporal/> .
@prefix cmns-av: <https://www.omg.org/spec/Commons/AnnotationVocabulary/> .
@prefix cmns-dt: <https://www.omg.org/spec/Commons/DatesAndTimes/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-fbc-fi-ip: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/InstrumentPricing/> .
@prefix fibo-fnd-dt-fd: <https://spec.edmcouncil.org/fibo/ontology/FND/DatesAndTimes/FinancialDates/> .
@prefix fibo-fnd-oac-own: <https://spec.edmcouncil.org/fibo/ontology/FND/OwnershipAndControl/Ownership/> .
@prefix fibo-fnd-rel-rel: <https://spec.edmcouncil.org/fibo/ontology/FND/Relations/Relations/> .
@prefix fibo-fnd-utl-av: <https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/> .
@prefix fibo-md-der-fut: <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/>
	a owl:Ontology ;
	rdfs:label "Futures Temporal Ontology"@en ;
	dcterms:abstract "Exchange traded futures date and time dependent terms such as prices and margining. Also covers greeks (thetas etc.)" ;
	dcterms:license "https://opensource.org/licenses/MIT"^^xsd:anyURI ;
	owl:imports
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/FinancialInstruments/InstrumentPricing/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/DatesAndTimes/FinancialDates/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/OwnershipAndControl/Ownership/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Relations/Relations/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/DatesAndTimes/>
		;
	owl:versionIRI <https://spec.edmcouncil.org/fibo/ontology/master/latest/MD/DerivativesTemporal/FuturesTemporal/> ;
	fibo-fnd-utl-av:hasMaturityLevel fibo-fnd-utl-av:Provisional ;
	cmns-av:copyright "Copyright (c) 2013-2023 EDM Council, Inc." ;
	.

fibo-md-der-fut:ExchangeFuturesPrice
	a owl:Class ;
	rdfs:subClassOf fibo-fbc-fi-ip:SecurityPrice ;
	rdfs:label "exchange futures price"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	.

fibo-md-der-fut:FuturesClosingPrice
	a owl:Class ;
	rdfs:subClassOf fibo-md-der-fut:ExchangeFuturesPrice ;
	rdfs:label "futures closing price"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	.

fibo-md-der-fut:FuturesDailySettlementPrice
	a owl:Class ;
	rdfs:subClassOf fibo-fbc-fi-ip:SecurityPrice ;
	rdfs:label "futures daily settlement price"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	skos:definition "Review whether this exists"@en ;
	.

fibo-md-der-fut:FuturesGreek
	a owl:Class ;
	rdfs:subClassOf fibo-fbc-fi-ip:PriceAnalytic ;
	rdfs:label "futures greek"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	skos:definition "quantity representing the sensitivity of the price of a future or futures to a change in underlying parameters on which the value depends"@en ;
	.

fibo-md-der-fut:FuturesTheta
	a owl:Class ;
	rdfs:subClassOf fibo-md-der-fut:FuturesGreek ;
	rdfs:label "futures theta"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	.

fibo-md-der-fut:FuturesTradingAccountHolder
	a owl:Class ;
	rdfs:label "futures trading account holder"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	skos:definition "A party who has an account for futures trading at a derivatives exchange. Further notes: The trader opens an account with a given amount known as a margin."@en ;
	.

fibo-md-der-fut:FuturesVega
	a owl:Class ;
	rdfs:subClassOf fibo-md-der-fut:FuturesGreek ;
	rdfs:label "futures vega"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	.

fibo-md-der-fut:InitialMargin
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-oac-own:Asset ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-dt-fd:hasAsOfDate ;
			owl:someValuesFrom cmns-dt:ExplicitDate ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-rel-rel:isHeldBy ;
			owl:someValuesFrom fibo-md-der-fut:FuturesTradingAccountHolder ;
		]
		;
	rdfs:label "initial margin"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	skos:definition "money or securities put up as a good faith deposit assuring that a future contract will be fulfilled"@en ;
	cmns-av:explanatoryNote "When you open a futures contract, the futures exchange will state a minimum amount of money that you must deposit into your account. This original deposit of money is called the initial margin. When your contract is liquidated, you will be refunded the initial margin plus or minus any gains or losses that occur over the span of the futures contract. In other words, the amount in your margin account changes daily as the market fluctuates in relation to your futures contract. The minimum-level margin is determined by the futures exchange and is usually 5% to 10% of the futures contract. These predetermined initial margin amounts are continuously under review: at times of high market volatility, initial margin requirements can be raised."@en ;
	cmns-av:synonym "security deposit"@en ;
	.

fibo-md-der-fut:MinimumMargin
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-oac-own:Asset ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-dt-fd:hasAsOfDate ;
			owl:someValuesFrom cmns-dt:ExplicitDate ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-rel-rel:isHeldBy ;
			owl:someValuesFrom fibo-md-der-fut:FuturesTradingAccountHolder ;
		]
		;
	rdfs:label "minimum margin"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/FuturesTemporal/> ;
	skos:definition "The lowest amount an account can reach before needing to be replenished."@en ;
	.

