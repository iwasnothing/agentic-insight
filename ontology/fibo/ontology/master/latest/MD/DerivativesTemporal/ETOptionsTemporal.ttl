	.

fibo-md-derx-eto:Delta
	a owl:Class ;
	rdfs:subClassOf fibo-md-derx-eto:OptionsGreek ;
	rdfs:label "delta"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/> ;
	skos:definition "First derivative of option value with respect to theoretical price is a delta (or on a position). Theoretical price"@en ;
	cmns-av:explanatoryNote "Delta tells you what options to buy to get the equivalent price sensitivity to the underlying. How many at that price to get that hedge. So for example an at the money option has a delta of 50. Units"@en ;
	.

fibo-md-derx-eto:OptionDailySettlementPrice
	a owl:Class ;
	rdfs:subClassOf
		fibo-fbc-fi-ip:ClosingPrice ,
		fibo-fbc-fi-ip:SecurityPrice ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-be-fct-pub:hasPublisher ;
			owl:someValuesFrom [
				a owl:Class ;
				owl:unionOf (
					fibo-fbc-fct-mkt:DesignatedContractMarket
					fibo-der-drc-bsc:DerivativesClearingOrganization
				) ;
			] ;
		]
		;
	rdfs:label "option daily settlement price"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/> ;
	skos:definition "The official price at the end of a trading session. This price is established by The Options Clearing Corporation and is used to determine changes in account equity, margin requirements, and for other purposes."@en ;
	.

fibo-md-derx-eto:OptionTheoreticalValue
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-acc-cur:MonetaryAmount ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-doc:refersTo ;
			owl:someValuesFrom fibo-fbc-fi-ip:PricingModel ;
		]
		;
	rdfs:label "option theoretical value"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/> ;
	skos:definition "fair value of the option as determined by an option pricing model"@en ;
	cmns-av:explanatoryNote "The pricing model (such as the Black-Scholes model) takes into account current values such as implied volatility, the price of the underlying, the strike price, and time to expiration to determine what an option should be worth. Each of the input values fluctuate, which means theoretical price will also be a fluctuating value."@en ;
	.

fibo-md-derx-eto:OptionsGreek
	a owl:Class ;
	rdfs:subClassOf fibo-fbc-fi-ip:PriceAnalytic ;
	rdfs:label "options greek"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/> ;
	skos:definition "quantity representing the sensitivity of the price of an option or options to a change in underlying parameters on which the value depends"@en ;
	.

fibo-md-derx-eto:OptionsTheta
	a owl:Class ;
	rdfs:subClassOf
		fibo-md-derx-eto:OptionsGreek ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-doc:refersTo ;
			owl:someValuesFrom fibo-md-derx-eto:OptionTheoreticalValue ;
		]
		;
	rdfs:label "options theta"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/> ;
	skos:definition "A measure of the rate of change in an option's theoretical value for a one-unit change in time to the option's expiration date. Action: add terms that define or influence this."@en ;
	.

fibo-md-derx-eto:OptionsVega
	a owl:Class ;
	rdfs:subClassOf
		fibo-md-derx-eto:OptionsGreek ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-doc:refersTo ;
			owl:someValuesFrom fibo-md-derx-eto:OptionTheoreticalValue ;
		]
		;
	rdfs:label "options vega"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/> ;
	skos:definition "A measure of the rate of change in an option's theoretical value for a one-unit change in the volatility assumption. Action: add terms that define or influence this."@en ;
	.

