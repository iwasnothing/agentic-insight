<https://spec.edmcouncil.org/fibo/ontology/MD/DerivativesTemporal/ETOptionsTemporal/>
	a owl:Ontology ;
	rdfs:label "Exchange-Traded Options Temporal"@en ;
	dcterms:abstract "Exchange traded options date and time dependent terms such as pricing and other analytics, including greeks (deltas, thetas etc.)" ;
	dcterms:license """Copyright (c) 2015-2025 EDM Council, Inc.
