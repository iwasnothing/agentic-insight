@base <https://spec.edmcouncil.org/fibo/ontology/master/latest/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> .
@prefix cmns-av: <https://www.omg.org/spec/Commons/AnnotationVocabulary/> .
@prefix cmns-dsg: <https://www.omg.org/spec/Commons/Designators/> .
@prefix cmns-dt: <https://www.omg.org/spec/Commons/DatesAndTimes/> .
@prefix cmns-pts: <https://www.omg.org/spec/Commons/PartiesAndSituations/> .
@prefix cmns-rlcmp: <https://www.omg.org/spec/Commons/RolesAndCompositions/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-be-le-usee: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleEntities/> .
@prefix fibo-be-le-usex: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> .
@prefix fibo-be-oac-cpty: <https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/> .
@prefix fibo-be-oac-exec: <https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/Executives/> .
@prefix fibo-fnd-aap-ppl: <https://spec.edmcouncil.org/fibo/ontology/FND/AgentsAndPeople/People/> .
@prefix fibo-fnd-org-fm: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/FormalOrganizations/> .
@prefix fibo-fnd-utl-av: <https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/> .
@prefix lcc-3166-1: <https://www.omg.org/spec/LCC/Countries/ISO3166-1-CountryCodes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/>
	a owl:Ontology ;
	rdfs:label "US Example Executives" ;
	dcterms:abstract "This ontology includes example corporate executives and other people to demonstrate how to model them using FIBO." ;
	dcterms:license "https://opensource.org/licenses/MIT"^^xsd:anyURI ;
	owl:imports
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/BE/LegalEntities/NorthAmericanEntities/USExampleEntities/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/BE/OwnershipAndControl/ControlParties/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/BE/OwnershipAndControl/Executives/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/AgentsAndPeople/People/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Organizations/FormalOrganizations/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Relations/Relations/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/DatesAndTimes/> ,
		<https://www.omg.org/spec/Commons/Designators/> ,
		<https://www.omg.org/spec/Commons/PartiesAndSituations/> ,
		<https://www.omg.org/spec/Commons/RolesAndCompositions/> ,
		<https://www.omg.org/spec/LCC/Countries/ISO3166-1-CountryCodes/>
		;
	owl:versionIRI <https://spec.edmcouncil.org/fibo/ontology/master/latest/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	fibo-fnd-utl-av:hasMaturityLevel fibo-fnd-utl-av:Provisional ;
	cmns-av:copyright
		"Copyright (c) 2022-2024 EDM Council, Inc." ,
		"Copyright (c) 2022-2024 Object Management Group, Inc."
		;
	.

fibo-be-le-usex:AppleIncAsControlledParty
	a
		owl:NamedIndividual ,
		fibo-be-oac-cpty:ControlledParty
		;
	rdfs:label "Apple Inc. as controlled party" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "Apple Inc. in its role as a corporation that is controlled to some degree by its corporate officers" ;
	cmns-rlcmp:isPlayedBy fibo-be-le-usee:AppleInc-US-CA ;
	.

fibo-be-le-usex:AppleIncAsEmployer
	a
		owl:NamedIndividual ,
		fibo-fnd-org-fm:Employer
		;
	rdfs:label "Apple Inc. as employer" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "Apple Inc. in its role as a corporation that has employees" ;
	cmns-rlcmp:isPlayedBy fibo-be-le-usee:AppleInc-US-CA ;
	.

fibo-be-le-usex:EmploymentOfKatherineAdamsAtAppleInc
	a
		owl:NamedIndividual ,
		fibo-fnd-org-fm:Employment
		;
	rdfs:label "Employment of Katherine Adams at Apple Inc." ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "situation representing the relationship between Apple Inc. as an employer and Katherine Adams as an employee" ;
	fibo-fnd-org-fm:hasEmployedParty fibo-be-le-usex:KatherineAdamsAsEmployee ;
	fibo-fnd-org-fm:hasEmployingParty fibo-be-le-usex:AppleIncAsEmployer ;
	.

fibo-be-le-usex:EmploymentOfTimCookAtAppleInc
	a
		owl:NamedIndividual ,
		fibo-fnd-org-fm:Employment
		;
	rdfs:label "Employment of Tim Cook at Apple Inc." ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "situation representing the relationship between Apple Inc. as an employer and Tim Cook as an employee" ;
	fibo-fnd-org-fm:hasEmployedParty fibo-be-le-usex:TimCookAsEmployee ;
	fibo-fnd-org-fm:hasEmployingParty fibo-be-le-usex:AppleIncAsEmployer ;
	cmns-pts:holdsDuring fibo-be-le-usex:TimCookPeriodOfEmployment ;
	.

fibo-be-le-usex:KatherineAdams
	a
		owl:NamedIndividual ,
		fibo-fnd-aap-ppl:Person
		;
	rdfs:label "Katherine Adams" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "person that is an American attorney and corporate lawyer" ;
	fibo-fnd-aap-ppl:hasCitizenship lcc-3166-1:UnitedStatesOfAmerica ;
	fibo-fnd-aap-ppl:hasDateOfBirth fibo-be-le-usex:KatherineAdamsDateOfBirth ;
	cmns-dsg:hasName fibo-be-le-usex:KatherineAdamsFullLegalName ;
	.

fibo-be-le-usex:KatherineAdamsAsEmployee
	a
		owl:NamedIndividual ,
		fibo-fnd-org-fm:Employee
		;
	rdfs:label "Katherine Adams as employee" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "Katherine Adams in the role of being employed by Apple Inc." ;
	fibo-fnd-org-fm:isEmployedIn fibo-be-le-usex:EmploymentOfKatherineAdamsAtAppleInc ;
	fibo-fnd-org-fm:isEmployeeOf fibo-be-le-usex:AppleIncAsEmployer ;
	cmns-rlcmp:isPlayedBy fibo-be-le-usex:KatherineAdams ;
	.

fibo-be-le-usex:KatherineAdamsAsGeneralCounsel
	a
		owl:NamedIndividual ,
		fibo-be-oac-exec:CorporateOfficer
		;
	rdfs:label "Katherine Adams as General Counsel" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "Katherine Adams in the role of Senior Vice President of Legal and Global Security and General Counsel of Apple Inc." ;
	fibo-be-oac-exec:isOfficerOf fibo-be-le-usex:AppleIncAsControlledParty ;
	cmns-rlcmp:isPlayedBy fibo-be-le-usex:KatherineAdams ;
	.

fibo-be-le-usex:KatherineAdamsDateOfBirth
	a
		owl:NamedIndividual ,
		fibo-fnd-aap-ppl:DateOfBirth
		;
	rdfs:label "Katherine Adams date of birth" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "date on which Katherine Adams was born" ;
	cmns-dt:hasDateValue "1964-04-20" ;
	.

fibo-be-le-usex:KatherineAdamsFullLegalName
	a
		owl:NamedIndividual ,
		fibo-fnd-aap-ppl:PersonName
		;
	rdfs:label "Katherine Adams full legal name" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "name that is on Katherine Adams' birth certificate and that she uses for legal purposes" ;
	fibo-fnd-aap-ppl:hasFullLegalName "Katherine Leatherman Adams" ;
	cmns-dsg:isNameOf fibo-be-le-usex:KatherineAdams ;
	.

fibo-be-le-usex:TimCook
	a
		owl:NamedIndividual ,
		fibo-fnd-aap-ppl:Person
		;
	rdfs:label "Tim Cook" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "person that lives in Palo Alto, California in the San Francisco Bay Area" ;
	fibo-fnd-aap-ppl:hasCitizenship lcc-3166-1:UnitedStatesOfAmerica ;
	fibo-fnd-aap-ppl:hasDateOfBirth fibo-be-le-usex:TimCookDateOfBirth ;
	cmns-dsg:hasName fibo-be-le-usex:TimCookFullLegalName ;
	.

fibo-be-le-usex:TimCookAsChiefExecutiveOfficer
	a
		owl:NamedIndividual ,
		fibo-be-oac-exec:ChiefExecutiveOfficer
		;
	rdfs:label "Tim Cook as Chief Executive Officer" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "Tim Cook in the role of CEO of Apple Inc." ;
	fibo-be-oac-exec:isOfficerOf fibo-be-le-usex:AppleIncAsControlledParty ;
	cmns-rlcmp:isPlayedBy fibo-be-le-usex:TimCook ;
	.

fibo-be-le-usex:TimCookAsEmployee
	a
		owl:NamedIndividual ,
		fibo-fnd-org-fm:Employee
		;
	rdfs:label "Tim Cook as employee" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "Tim Cook in the role of being employed by Apple Inc." ;
	fibo-fnd-org-fm:isEmployedIn fibo-be-le-usex:EmploymentOfTimCookAtAppleInc ;
	fibo-fnd-org-fm:isEmployeeOf fibo-be-le-usex:AppleIncAsEmployer ;
	cmns-rlcmp:isPlayedBy fibo-be-le-usex:TimCook ;
	.

fibo-be-le-usex:TimCookDateOfBirth
	a
		owl:NamedIndividual ,
		fibo-fnd-aap-ppl:DateOfBirth
		;
	rdfs:label "Tim Cook date of birth" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "date on which Tim Cook was born" ;
	cmns-dt:hasDateValue "1960-11-01" ;
	.

fibo-be-le-usex:TimCookFullLegalName
	a
		owl:NamedIndividual ,
		fibo-fnd-aap-ppl:PersonName
		;
	rdfs:label "Tim Cook full legal name" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "name that is on Tim Cook's birth certificate and that he uses for legal purposes" ;
	fibo-fnd-aap-ppl:hasFullLegalName "Timothy Donald Cook" ;
	cmns-dsg:isNameOf fibo-be-le-usex:TimCook ;
	.

fibo-be-le-usex:TimCookHireDate
	a
		owl:NamedIndividual ,
		cmns-dt:ExplicitDate
		;
	rdfs:label "Tim Cook hire date" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "date on which Tim Cook was hired by Apple Inc." ;
	cmns-dt:hasDateValue "1998-03-01" ;
	.

fibo-be-le-usex:TimCookPeriodOfEmployment
	a
		owl:NamedIndividual ,
		cmns-dt:DatePeriod
		;
	rdfs:label "Tim Cook period of employment" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/NorthAmericanEntities/USExampleExecutives/> ;
	skos:definition "date period reflecting when Tim Cook was (is) employed by Apple Inc." ;
	cmns-dt:hasStartDate fibo-be-le-usex:TimCookHireDate ;
	.

