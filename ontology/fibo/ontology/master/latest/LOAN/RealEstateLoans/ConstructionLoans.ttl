# baseURI: https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/RealEstateLoans/ConstructionLoans/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/DebtAndEquities/Debt/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/ProductsAndServices/ClientsAndAccounts/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Accounting/CurrencyAmount/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Agreements/Contracts/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Places/RealProperty/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansGeneral/Loans/
# imports: https://www.omg.org/spec/Commons/AnnotationVocabulary/
# imports: https://www.omg.org/spec/Commons/Classifiers/

@base <https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/RealEstateLoans/ConstructionLoans/> .
@prefix cmns-av: <https://www.omg.org/spec/Commons/AnnotationVocabulary/> .
@prefix cmns-cls: <https://www.omg.org/spec/Commons/Classifiers/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-fbc-dae-dbt: <https://spec.edmcouncil.org/fibo/ontology/FBC/DebtAndEquities/Debt/> .
@prefix fibo-fnd-acc-cur: <https://spec.edmcouncil.org/fibo/ontology/FND/Accounting/CurrencyAmount/> .
@prefix fibo-fnd-agr-ctr: <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/> .
@prefix fibo-fnd-plc-rp: <https://spec.edmcouncil.org/fibo/ontology/FND/Places/RealProperty/> .
@prefix fibo-fnd-utl-av: <https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/> .
@prefix fibo-loan-ln-ln: <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansGeneral/Loans/> .
@prefix fibo-loan-reln-cnst: <https://spec.edmcouncil.org/fibo/ontology/LOAN/RealEstateLoans/ConstructionLoans/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spec.edmcouncil.org/fibo/ontology/LOAN/RealEstateLoans/ConstructionLoans/>
	a owl:Ontology ;
	rdfs:label "Construction Loans Ontology"@en ;
	dcterms:abstract "Construction loans are credit facilities with separate draw-downs (which may be specified through sub-facilities for large projects) allowed given evidence of completion, or substantial completion, of agreed milestones of the construction project." ;
	dcterms:license "https://opensource.org/licenses/MIT"^^xsd:anyURI ;
	owl:imports
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/DebtAndEquities/Debt/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/ProductsAndServices/ClientsAndAccounts/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Accounting/CurrencyAmount/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Agreements/Contracts/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Places/RealProperty/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansGeneral/Loans/> ,
		<https://www.omg.org/spec/Commons/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/Classifiers/>
		;
	owl:versionIRI <https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/RealEstateLoans/ConstructionLoans/> ;
	fibo-fnd-utl-av:hasMaturityLevel fibo-fnd-utl-av:Provisional ;
	cmns-av:copyright
		"Copyright (c) 2016-2024 EDM Council, Inc." ,
		"Copyright (c) 2016-2024 Object Management Group, Inc."
		;
	.

fibo-loan-reln-cnst:ConstructionLoan
	a owl:Class ;
	rdfs:subClassOf
		fibo-fbc-dae-dbt:CreditFacility ,
		fibo-fnd-agr-ctr:MasterAgreement ,
		fibo-loan-ln-ln:CollateralizedLoan ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-agr-ctr:hasMilestoneProvision ;
			owl:onClass fibo-fnd-agr-ctr:ContractMilestone ;
			owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fbc-dae-dbt:isCollateralizedBy ;
			owl:onClass fibo-fnd-plc-rp:RealProperty ;
			owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
		]
		;
	rdfs:label "construction loan"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/RealEstateLoans/ConstructionLoans/> ;
	skos:definition "loan covering construction and development costs, secured by a mortgage on the property financed"@en ;
	cmns-av:explanatoryNote
		"A construction loan credit facility tranche (sub-facility) is a portion of a construction loan that is released in stages, or tranches, to fund specific phases of a construction project. Each tranche (committed sub-facility) is released once the borrower reaches a certain milestone, such as pouring concrete or completing the foundation. The borrower typically only pays interest on the amount that has been released at any given time."@en ,
		"The Project Management Institute (PMI) breaks down most construction projects into five phases, which are initiation, planning, execution, monitoring and control, and closeout. Construction loans also typically include milestones at which a portion of the total facility is advanced to the borrower given proof of completion or meeting other requirements with respect to the work."@en
		;
	.

fibo-loan-reln-cnst:hasMaximumAllowedBalance
	a owl:ObjectProperty ;
	rdfs:subPropertyOf fibo-fbc-dae-dbt:hasAvailableAmount ;
	rdfs:label "has maximum allowed balance"@en ;
	rdfs:domain [
		a owl:Class ;
		owl:unionOf (
			fibo-loan-reln-cnst:ConstructionLoan
			fibo-fbc-dae-dbt:SubFacility
		) ;
	] ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/RealEstateLoans/ConstructionLoans/> ;
	rdfs:range fibo-fnd-acc-cur:MonetaryAmount ;
	skos:definition "maximum balance that may be outstanding at any time, below the credit limit, for loans with flexible re-draw facilities"@en ;
	.

fibo-loan-reln-cnst:hasMaximumAnticipatedBalance
	a owl:ObjectProperty ;
	rdfs:subPropertyOf fibo-fbc-dae-dbt:hasAvailableAmount ;
	rdfs:label "has maximum anticipated balance"@en ;
	rdfs:domain [
		a owl:Class ;
		owl:unionOf (
			fibo-loan-reln-cnst:ConstructionLoan
			fibo-fbc-dae-dbt:SubFacility
		) ;
	] ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/RealEstateLoans/ConstructionLoans/> ;
	rdfs:range fibo-fnd-acc-cur:MonetaryAmount ;
	skos:definition "maximum balance the borrower believes they might need, below the credit limit, for planning purposes, for loans with flexible re-draw facilities"@en ;
	.

fibo-loan-reln-cnst:hasMilestoneMaximumDrawdownAmount
	a owl:ObjectProperty ;
	rdfs:subPropertyOf fibo-fbc-dae-dbt:hasAvailableAmount ;
	rdfs:label "has milestone maximum drawdown amount"@en ;
	rdfs:domain fibo-fnd-agr-ctr:ContractMilestone ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/RealEstateLoans/ConstructionLoans/> ;
	rdfs:range fibo-fnd-acc-cur:MonetaryAmount ;
	skos:definition "maximum amount of the loan that can be drawn by the borrower on completion of the milestone"@en ;
	.

