		"Hypercube Ltd." ,
		"Intuitive Technology Partners, Inc." ,
		"John F. Gemski" ,
		"Office of Financial Research (US Dept of the Treasury)" ,
		"Semantic Arts, Inc." ,
		"Tahoe Blue Ltd" ,
		"Thematix Partners, LLC" ,
		"Wells Fargo" ,
		"agnos.ai U.K. Ltd"
		;
