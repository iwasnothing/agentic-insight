# baseURI: https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansSpecific/MarineFinance/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansGeneral/Loans/
# imports: https://www.omg.org/spec/Commons/AnnotationVocabulary/
# imports: https://www.omg.org/spec/Commons/QuantitiesAndUnits/

@base <https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansSpecific/MarineFinance/> .
@prefix cmns-av: <https://www.omg.org/spec/Commons/AnnotationVocabulary/> .
@prefix cmns-qtu: <https://www.omg.org/spec/Commons/QuantitiesAndUnits/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-fnd-utl-av: <https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/> .
@prefix fibo-loan-ln-ln: <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansGeneral/Loans/> .
@prefix fibo-loan-spc-mar: <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/>
	a owl:Ontology ;
	rdfs:label "Marine Finance Ontology"@en ;
	dcterms:abstract "This ontology defines concepts specific to marine finance, which involves financing vessel acquisitions for the spot market, time charters or bareboat charters, as well as the construction of work boats, and to finance the acquisition of vessels for scrapping." ;
	dcterms:license "https://opensource.org/licenses/MIT"^^xsd:anyURI ;
	owl:imports
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansGeneral/Loans/> ,
		<https://www.omg.org/spec/Commons/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/QuantitiesAndUnits/>
		;
	owl:versionIRI <https://spec.edmcouncil.org/fibo/ontology/master/latest/LOAN/LoansSpecific/MarineFinance/> ;
	fibo-fnd-utl-av:hasMaturityLevel fibo-fnd-utl-av:Provisional ;
	cmns-av:copyright "Copyright (c) 2015-2023 EDM Council, Inc." ;
	.

fibo-loan-spc-mar:MarineFinancing
	a owl:Class ;
	rdfs:subClassOf fibo-loan-ln-ln:Loan ;
	rdfs:label "marine finance"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/> ;
	skos:definition "A loan for the purchase of a boat or other vessel."@en ;
	.

fibo-loan-spc-mar:boatHeldAsChattel
	a owl:DatatypeProperty ;
	rdfs:label "boat held as chattel"@en ;
	rdfs:domain fibo-loan-spc-mar:MarineFinancing ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/> ;
	rdfs:range xsd:boolean ;
	skos:definition "Whether the vessel is to be held in ownership as a form of chattel by the lender during the period of the loan."@en ;
	.

fibo-loan-spc-mar:mooredAt
	a owl:DatatypeProperty ;
	rdfs:label "moored at"@en ;
	rdfs:domain fibo-loan-spc-mar:MarineFinancing ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/> ;
	rdfs:range xsd:string ;
	skos:definition "Textual description (name etc.) of where the vessel is to be moored if it has a permanent mooring place."@en ;
	.

fibo-loan-spc-mar:percentageAdvanced
	a owl:ObjectProperty ;
	rdfs:label "percentage advanced"@en ;
	rdfs:domain fibo-loan-spc-mar:MarineFinancing ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/> ;
	rdfs:range cmns-qtu:Percentage ;
	skos:definition "The percentage of the purchase price advanced as the loan."@en ;
	.

fibo-loan-spc-mar:residential
	a owl:DatatypeProperty ;
	rdfs:label "residential"@en ;
	rdfs:domain fibo-loan-spc-mar:MarineFinancing ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/LOAN/LoansSpecific/MarineFinance/> ;
	rdfs:range xsd:boolean ;
	skos:definition "Whether the boat is intended to be used and is legally able to be used as a place of residence."@en ;
	.

