		See https://opensource.org/licenses/MIT.""" ;
	owl:imports
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/BP/SecuritiesIssuance/IssuanceDocuments/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/BP/SecuritiesIssuance/IssuanceProcess/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/FinancialInstruments/FinancialInstruments/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/FunctionalEntities/Markets/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FBC/ProductsAndServices/FinancialProductsAndServices/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Accounting/CurrencyAmount/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/DatesAndTimes/Occurrences/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/SEC/Securities/SecuritiesListings/> ,
		<https://www.omg.org/spec/Commons/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/ContextualDesignators/> ,
		<https://www.omg.org/spec/Commons/DatesAndTimes/> ,
		<https://www.omg.org/spec/Commons/Documents/> ,
		<https://www.omg.org/spec/Commons/Organizations/> ,
		<https://www.omg.org/spec/Commons/PartiesAndSituations/> ,
		<https://www.omg.org/spec/Commons/RegistrationAuthorities/> ,
		<https://www.omg.org/spec/Commons/RolesAndCompositions/>
		;
	owl:versionIRI <https://spec.edmcouncil.org/fibo/ontology/master/latest/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	fibo-fnd-utl-av:hasMaturityLevel fibo-fnd-utl-av:Provisional ;
	cmns-av:copyright "Copyright (c) 2013-2025 EDM Council, Inc." ;
	.

fibo-bp-iss-ipo:AgreeBasisForAllocation
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "agree basis for allocation"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:Allocation
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "allocation"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:AllocationBasisDetails
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "allocation basis details"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:AllocationDetails
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "allocation details"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:AnnounceEquityIssue
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "announce equity issue"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:ApplicationForShares
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "application for shares"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:AppointAdvisors
	a owl:Class ;
	rdfs:subClassOf
		fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-org:designates ;
			owl:someValuesFrom [
				a owl:Class ;
				owl:unionOf (
					fibo-bp-iss-ipo:CorporateBroker
					fibo-bp-iss-ipo:Sponsor
					fibo-bp-iss-ipo:ReportingAccountant
					cmns-ra:RegistrationAuthority
				) ;
			] ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-rlcmp:playsRole ;
			owl:someValuesFrom fibo-fbc-fi-fi:Issuer ;
		]
		;
	rdfs:label "appoint advisors"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:ApproveForFlotation
	a owl:Class ;
	rdfs:subClassOf
		fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-org:isProvidedBy ;
			owl:someValuesFrom fibo-fbc-fct-mkt:Exchange ;
		]
		;
	rdfs:label "approve for flotation"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:CorporateBroker
	a owl:Class ;
	rdfs:subClassOf fibo-fbc-pas-fpas:Broker ;
	rdfs:label "corporate broker"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:EquityAnnouncement
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Notice ;
	rdfs:label "equity announcement"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:FilingDetails
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "filing details"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:FormalApprovalForListingAndTrading
	a owl:Class ;
	rdfs:subClassOf
		fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-org:isProvidedBy ;
			owl:someValuesFrom fibo-fbc-fct-mkt:Exchange ;
		]
		;
	rdfs:label "formal approval for listing and trading"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:IPOFullProspectus
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-doc:FinalProspectus ;
	rdfs:label "i p o full prospectus"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:IPOPreliminaryProspectus
	a owl:Class ;
	rdfs:subClassOf
		fibo-bp-iss-doc:PreliminaryProspectus ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dt:precedes ;
			owl:someValuesFrom fibo-bp-iss-ipo:IPOFullProspectus ;
		]
		;
	rdfs:label "i p o preliminary prospectus"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:IPOProcess
	a owl:Class ;
	rdfs:subClassOf [
		a owl:Restriction ;
		owl:onProperty cmns-dt:hasDatePeriod ;
		owl:someValuesFrom cmns-dt:DatePeriod ;
	] ;
	rdfs:label "i p o process"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:IPOSettlementDetails
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "i p o settlement details"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:IndicationOfInterest
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "indication of interest"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:InitialPublicOfferingProcessStep
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-dt-oc:OccurrenceKind ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-cxtdsg:appliesTo ;
			owl:someValuesFrom fibo-bp-iss-ipo:IPOProcess ;
		]
		;
	rdfs:label "initial public offering process step" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	cmns-av:abbreviation "IPO process step" ;
	.

fibo-bp-iss-ipo:MarketingOfShareIssue
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "marketing of share issue"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:NoticeOfAllocation
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "notice of allocation"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:PotentialShareUnderwriter
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-prc:PotentialUnderwriter ;
	rdfs:label "potential share underwriter"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:PublishInitialProspectus
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "publish initial prospectus"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:PurchasePrice
	a owl:Class ;
	rdfs:subClassOf fibo-fnd-acc-cur:MonetaryPrice ;
	rdfs:label "purchase price"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:PurchaseUnallocatedStock
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "purchase unallocated stock"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:ReceiveApplications
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "receive applications"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:RegisterWithRegulatoryAuthority
	a owl:Class ;
	rdfs:subClassOf
		fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-org:isProvidedBy ;
			owl:someValuesFrom fibo-fbc-fct-mkt:Exchange ;
		]
		;
	rdfs:label "register with regulatory authority"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:RegistrationStatementDocument
	a owl:Class ;
	rdfs:subClassOf cmns-doc:Document ;
	rdfs:label "registration statement document"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:ReportingAccountant
	a owl:Class ;
	rdfs:subClassOf cmns-pts:PartyRole ;
	rdfs:label "reporting accountant"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:SetPrice
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "set price"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:SettlementOfAllocatedShares
	a owl:Class ;
	rdfs:subClassOf fibo-bp-iss-ipo:InitialPublicOfferingProcessStep ;
	rdfs:label "settlement of allocated shares"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:ShareRegister
	a owl:Class ;
	rdfs:subClassOf cmns-ra:Registry ;
	rdfs:label "share register"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:Sponsor
	a owl:Class ;
	rdfs:subClassOf
		cmns-pts:PartyRole ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-bp-iss-ipo:mayBe ;
			owl:someValuesFrom fibo-bp-iss-ipo:CorporateBroker ;
		]
		;
	rdfs:label "sponsor"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:SyndicateMember
	a owl:Class ;
	rdfs:subClassOf cmns-pts:PartyRole ;
	rdfs:label "syndicate member"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:Underwriting
	a owl:Class ;
	rdfs:subClassOf
		[
			a owl:Restriction ;
			owl:onProperty fibo-bp-iss-ipo:shareUnderwriter ;
			owl:someValuesFrom fibo-bp-iss-ipo:PotentialShareUnderwriter ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-bp-iss-ipo:syndicateMember ;
			owl:someValuesFrom fibo-bp-iss-ipo:SyndicateMember ;
		]
		;
	rdfs:label "underwriting"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	.

fibo-bp-iss-ipo:lead
	a owl:ObjectProperty ;
	rdfs:label "lead"@en ;
	rdfs:domain fibo-bp-iss-ipo:AppointAdvisors ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	rdfs:range fibo-bp-iss-ipo:Sponsor ;
	.

fibo-bp-iss-ipo:mayBe
	a owl:ObjectProperty ;
	rdfs:label "may be"@en ;
	rdfs:domain fibo-bp-iss-ipo:Sponsor ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	rdfs:range fibo-bp-iss-ipo:CorporateBroker ;
	.

fibo-bp-iss-ipo:shareUnderwriter
	a owl:ObjectProperty ;
	rdfs:label "share underwriter"@en ;
	rdfs:domain fibo-bp-iss-ipo:Underwriting ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	rdfs:range fibo-bp-iss-ipo:PotentialShareUnderwriter ;
	.

fibo-bp-iss-ipo:syndicateMember
	a owl:ObjectProperty ;
	rdfs:label "syndicate member"@en ;
	rdfs:domain fibo-bp-iss-ipo:Underwriting ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/BP/SecuritiesIssuance/EquitiesIPOIssuance/> ;
	rdfs:range fibo-bp-iss-ipo:SyndicateMember ;
	.

