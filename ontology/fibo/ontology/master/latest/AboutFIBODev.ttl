<https://spec.edmcouncil.org/fibo/ontology/AboutFIBODev/>
	a owl:Ontology ;
	rdfs:label "About FIBO Development" ;
	dct:abstract "This ontology is provided for the convenience of FIBO users. It loads the very latest version of every FIBO ontology (released, provisional, and informative) based on the contents of GitHub, for use in particular while working on revisions. Note that metadata files and other 'load' files, such as the various domain-specific 'all' files, are intentionally excluded." ;
	dct:issued "2018-03-31T18:00:00"^^xsd:dateTime ;
