	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FBC/FunctionalEntities/EuropeanEntities/EURegulatoryAgencies/> ;
	skos:definition "Prudential Regulatory Authority entity, which is an agency of the Bank of England, responsible for the prudential regulation and supervision of banks, building societies, credit unions, insurers and major investment firms" ;
	fibo-be-le-fbo:hasHeadquartersAddress fibo-fbc-fct-eurga:PrudentialRegulatoryAuthorityHeadquartersAndLegalAddress ;
	fibo-fnd-rel-rel:hasLegalName "Prudential Regulatory Authority" ;
	cmns-av:abbreviation "PRA" ;
	cmns-org:hasWebsite "https://pra.directory/"^^xsd:anyURI ;
	.

