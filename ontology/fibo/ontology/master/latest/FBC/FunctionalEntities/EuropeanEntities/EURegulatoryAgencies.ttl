	fibo-be-le-fbo:hasHeadquartersAddress fibo-fbc-fct-eurga:FinancialConductAuthorityHeadquartersAndLegalAddress ;
	fibo-fnd-rel-rel:hasLegalName "Financial Conduct Authority" ;
	cmns-av:abbreviation "FCA" ;
