	.

fibo-fbc-fct-eurga:PrudentialRegulatoryAuthority
	a
		owl:NamedIndividual ,
		cmns-rga:RegulatoryAgency
		;
	rdfs:label "Prudential Regulatory Authority" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FBC/FunctionalEntities/EuropeanEntities/EURegulatoryAgencies/> ;
	skos:definition "Prudential Regulatory Authority, which is an agency of the Bank of England, responsible for the prudential regulation and supervision of banks, building societies, credit unions, insurers and major investment firms" ;
	cmns-rga:hasJurisdiction fibo-be-ge-ukj:UnitedKingdomJurisdiction ;
	cmns-rlcmp:isPlayedBy fibo-fbc-fct-eurga:PrudentialRegulatoryAuthorityEntity ;
	.

