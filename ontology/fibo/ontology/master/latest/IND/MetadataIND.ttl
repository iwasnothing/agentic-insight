		"John F. Gemski" ,
		"John F. Tierney" ,
		"Nordea Bank AB" ,
		"Office of Financial Research (OFR), U.S. Department of the Treasury" ,
		"Pinnacle Bank (Morgan Hill, California)" ,
		"State Street Bank and Trust" ,
		"Statistics Canada" ,
		"Tahoe Blue Ltd" ,
		"Thematix Partners, LLC" ,
		"Wells Fargo Bank, N. A." ,
		"agnos.ai UK Ltd"
		;
