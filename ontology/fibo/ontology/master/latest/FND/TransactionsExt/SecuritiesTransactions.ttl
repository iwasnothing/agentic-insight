# baseURI: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/SecuritiesTransactions/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Accounting/CurrencyAmount/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Agreements/Contracts/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/MarketTransactions/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/REATransactions/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/
# imports: https://www.omg.org/spec/Commons/AnnotationVocabulary/
# imports: https://www.omg.org/spec/Commons/RegulatoryAgencies/

@base <https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/SecuritiesTransactions/> .
@prefix cmns-av: <https://www.omg.org/spec/Commons/AnnotationVocabulary/> .
@prefix cmns-rga: <https://www.omg.org/spec/Commons/RegulatoryAgencies/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-fnd-acc-cur: <https://spec.edmcouncil.org/fibo/ontology/FND/Accounting/CurrencyAmount/> .
@prefix fibo-fnd-agr-ctr: <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/> .
@prefix fibo-fnd-txn-mkt: <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/MarketTransactions/> .
@prefix fibo-fnd-txn-rea: <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/REATransactions/> .
@prefix fibo-fnd-txn-sec: <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> .
@prefix fibo-fnd-utl-av: <https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/>
	a owl:Ontology ;
	rdfs:label "Securities Transactions Ontology"@en ;
	dcterms:abstract "Describes the basic concepts for securities transactions, as an extension of market transactions more generally. Incudes types of securities transactions, parties to the transaction, settlement and the covering contract for the transaction. This ontology would form the basis for more detailed securities transaction concepts that would ideally be derived from the FIX standard." ;
	dcterms:license """Copyright (c) 2013-2025 EDM Council, Inc.
Copyright (c) 2013-2025 Object Management Group, Inc.
		
Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the 'Software'), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED 'AS IS', WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.
		
		See https://opensource.org/licenses/MIT.""" ;
	owl:imports
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Accounting/CurrencyAmount/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Agreements/Contracts/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/MarketTransactions/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/REATransactions/> ,
		<https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/Utilities/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/AnnotationVocabulary/> ,
		<https://www.omg.org/spec/Commons/RegulatoryAgencies/>
		;
	owl:versionIRI <https://spec.edmcouncil.org/fibo/ontology/master/latest/FND/TransactionsExt/SecuritiesTransactions/> ;
	fibo-fnd-utl-av:hasMaturityLevel fibo-fnd-utl-av:Informative ;
	cmns-av:copyright "Copyright (c) 2013-2025 EDM Council, Inc." ;
	.

fibo-fnd-txn-sec:FinancialPrimaryMarketTransaction
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-txn-mkt:MarketTransaction ,
		fibo-fnd-txn-rea:ContractualTransaction ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-txn-sec:follows ;
			owl:someValuesFrom fibo-fnd-txn-sec:SettlementProcess ;
		]
		;
	rdfs:label "financial primary market transaction"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	.

fibo-fnd-txn-sec:FinancialSecuritiesSecondaryMarketTransaction
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-txn-mkt:MarketTransaction ,
		fibo-fnd-txn-rea:ContractualTransaction ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-agr-ctr:hasCounterparty ;
			owl:someValuesFrom fibo-fnd-txn-sec:SecuritiesTransactionCounterparty ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-agr-ctr:hasPrincipalParty ;
			owl:someValuesFrom fibo-fnd-txn-sec:SecuritiesTransactionPrincipal ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-txn-mkt:consideration ;
			owl:someValuesFrom [
				a owl:Class ;
				owl:unionOf (
					fibo-fnd-acc-cur:AmountOfMoney
					<https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/Security>
				) ;
			] ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-txn-rea:subject ;
			owl:someValuesFrom <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/Security> ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-txn-sec:embodies ;
			owl:someValuesFrom fibo-fnd-txn-sec:SecuritiesTransactionContract ;
		]
		;
	rdfs:label "financial securities secondary market transaction"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	skos:definition "A Transaction in which some negotiable security is provided in exchange for some Consideration."@en ;
	.

fibo-fnd-txn-sec:SecuritiesTransactionContract
	a owl:Class ;
	rdfs:subClassOf
		fibo-fnd-txn-rea:EconomicContract ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-fnd-txn-sec:governs ;
			owl:someValuesFrom fibo-fnd-txn-sec:FinancialSecuritiesSecondaryMarketTransaction ;
		]
		;
	rdfs:label "securities transaction contract"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	skos:definition "The contract (written or implied) which governs the transaction of securities in the secondary Market."@en ;
	skos:editorialNote 'This is in line with the REA Ontology in which all Transactions are embodied in some Contract, whether written or implied. forms part of future "Transaction" model to be reviewed, but is ancestral to Options contract and transactions model.'@en ;
	.

fibo-fnd-txn-sec:SecuritiesTransactionCounterparty
	a owl:Class ;
	rdfs:subClassOf fibo-fnd-txn-mkt:TransactionCounterparty ;
	rdfs:label "securities transaction counterparty"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	.

fibo-fnd-txn-sec:SecuritiesTransactionPrincipal
	a owl:Class ;
	rdfs:subClassOf fibo-fnd-txn-mkt:TransactionPrincipal ;
	rdfs:label "securities transaction principal"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	.

fibo-fnd-txn-sec:SettlementProcess
	a owl:Class ;
	rdfs:label "settlement process"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	.

fibo-fnd-txn-sec:WhenIssuedTransaction
	a owl:Class ;
	rdfs:subClassOf fibo-fnd-txn-sec:FinancialSecuritiesSecondaryMarketTransaction ;
	rdfs:label "when issued transaction"@en ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	skos:definition "Trading in securities ahead of them being traded."@en ;
	.

fibo-fnd-txn-sec:embodies
	a owl:ObjectProperty ;
	rdfs:subPropertyOf fibo-fnd-txn-rea:transactionEmbodiesEconomicAgreement ;
	rdfs:label "embodies"@en ;
	rdfs:domain fibo-fnd-txn-sec:FinancialSecuritiesSecondaryMarketTransaction ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	rdfs:range fibo-fnd-txn-sec:SecuritiesTransactionContract ;
	.

fibo-fnd-txn-sec:follows
	a owl:ObjectProperty ;
	rdfs:subPropertyOf fibo-fnd-txn-rea:transactionEventFollowsBusinessProcess ;
	rdfs:label "follows"@en ;
	rdfs:domain fibo-fnd-txn-sec:FinancialPrimaryMarketTransaction ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	rdfs:range fibo-fnd-txn-sec:SettlementProcess ;
	.

fibo-fnd-txn-sec:governs
	a owl:ObjectProperty ;
	rdfs:subPropertyOf cmns-rga:governs ;
	rdfs:label "governs"@en ;
	rdfs:domain fibo-fnd-txn-sec:SecuritiesTransactionContract ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	rdfs:range fibo-fnd-txn-sec:FinancialSecuritiesSecondaryMarketTransaction ;
	owl:inverseOf fibo-fnd-txn-sec:embodies ;
	.

fibo-fnd-txn-sec:offsetForWIIssueDate
	a owl:DatatypeProperty ;
	rdfs:label "offset for w i issue date"@en ;
	rdfs:domain fibo-fnd-txn-sec:WhenIssuedTransaction ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/FND/TransactionsExt/SecuritiesTransactions/> ;
	rdfs:range xsd:integer ;
	skos:definition "Used to calculate actual settlement date from given WI issue date. If issue date is unknwn, this determines how many days form the issue date it's going to settle."@en ;
	.

