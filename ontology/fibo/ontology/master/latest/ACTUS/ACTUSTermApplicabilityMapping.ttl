# baseURI: https://spec.edmcouncil.org/fibo/ontology/master/latest/ACTUS/ACTUSTermApplicabilityMapping/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/ACTUS/ACTUSContractTerms/
# imports: https://spec.edmcouncil.org/fibo/ontology/master/latest/ACTUS/ACTUSTaxonomy/
