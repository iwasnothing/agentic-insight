	fibo-actus-act:hasParameterName "seniority" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Counterparty ;
	cmns-dsg:hasDescription "Refers to the order of repayment in the event of a sale or default of the issuer." ;
	cmns-dsg:hasTag "SEN" ;
	cmns-dsg:hasTextualName "Seniority" ;
	.

fibo-actus-act:ACTUSContractTerm-STP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - STP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "settlementPeriod" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Settlement ;
	cmns-dsg:hasDescription "Defines the period from fixing of a contingent event/obligation (Exercise Date) to settlement of the obligation." ;
	cmns-dsg:hasTag "STP" ;
	cmns-dsg:hasTextualName "Settlement Period" ;
	.

fibo-actus-act:ACTUSContractTerm-TD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - TD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "terminationDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """If a contract is sold before MD (for example a bond on the secondary market) this date has to be set. It refers to the date at which the payment (of PTD) and transfer of the security happens. In other words, TD - if set - takes the role otherwise MD has from a cash flow perspective. 

Note, CPID of the CT is not the counterparty of the transaction!""" ;
	cmns-dsg:hasTag "TD" ;
	cmns-dsg:hasTextualName "Termination Date" ;
	.

fibo-actus-act:ACTUSContractTerm-UT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - UT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "unit" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "The physical unit of the contract. Example: Barrels for an Oil COM CT." ;
	cmns-dsg:hasTag "UT" ;
	cmns-dsg:hasTextualName "Unit" ;
	.

fibo-actus-act:ACTUSContractTerm-XA
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - XA" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "exerciseAmount" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Settlement ;
	cmns-dsg:hasDescription "The amount fixed at Exercise Date for a contingent event/obligation such as a forward condition, optionality etc. The Exercise Amount is fixed at Exercise Date but not settled yet." ;
	cmns-dsg:hasTag "XA" ;
	cmns-dsg:hasTextualName "Exercise Amount" ;
	.

fibo-actus-act:ACTUSContractTerm-XD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - XD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "exerciseDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Settlement ;
	cmns-dsg:hasDescription "Date of exercising a contingent event/obligation such as a forward condition, optionality etc. The Exercise date marks the observed timestamp of fixing the contingent event and respective payment obligation not necessarily the timestamp of settling the obligation." ;
	cmns-dsg:hasTag "XD" ;
	cmns-dsg:hasTextualName "Exercise Date" ;
	.

fibo-actus-act:ACTUSContractTerm-XDN
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - XDN" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "xDayNotice" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Used as rolling attribute with the callable CT's UMP and CLM uniquely. CLM's and UMP's will not be settled (MD not set) until the client uses his option to call the contract X_Day_Notice after Current Date. As long as MD or TD is not set, the client postpones his right to call to the future. The cycle is normally defined in number of business days." ;
	cmns-dsg:hasTag "XDN" ;
	cmns-dsg:hasTextualName "X Day Notice" ;
	.

fibo-actus-act:ACTUSContractTermGroup
	a owl:Class ;
	rdfs:subClassOf
		cmns-cls:Classifier ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:isDefinedIn ;
			owl:hasValue fibo-actus-act:AlgorithmicContractTypesDataDictionary ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-cls:classifies ;
			owl:someValuesFrom fibo-actus-act:ACTUSContractTerm ;
		]
		;
	rdfs:label "ACTUS dictionary term group" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "classifier for a collection of ACTUS dictionary parameters that tend to be applied together" ;
	.

