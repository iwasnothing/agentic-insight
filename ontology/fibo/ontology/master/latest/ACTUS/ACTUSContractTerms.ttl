	.

fibo-actus-act:ACTUSBusinessDayConvention
	a owl:Class ;
	rdfs:subClassOf
		cmns-cds:CodeElement ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:isDefinedIn ;
			owl:hasValue fibo-actus-act:AlgorithmicContractTypesDataDictionary ;
		]
		;
	rdfs:label "ACTUS business day convention" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "code element for one of a set of conventions that ACTUS supports" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-CSF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - CSF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a scheduled date will be calculated from a formula, coupon schedule, or tenor first, then if it falls on a non-business date will be adjusted to the first following day that is a business day" ;
	cmns-dsg:hasTag "CSF" ;
	cmns-dsg:hasTextualName "Calculate/Shift following" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-CSMF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - CSMF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a scheduled date will be calculated from a formula, coupon schedule, or tenor first, then if it falls on a non-business date will be shifted to the first following day that is a business day unless that day falls in the next calendar month, in which case that date will be the first preceding day that is a calendar date" ;
	cmns-dsg:hasTag "CSMF" ;
	cmns-dsg:hasTextualName "Calculate/Shift modified following" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-CSMP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - CSMP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a scheduled date will be calculated from a formula, coupon schedule, or tenor first, then if it falls on a non-business date will be shifted to the first preceding day that is a business day unless that day falls in the prior calendar month, in which case that date will be the first subsequent day that is a calendar date" ;
	cmns-dsg:hasTag "CSMP" ;
	cmns-dsg:hasTextualName "Calculate/Shift modified preceding" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-CSP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - CSP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a scheduled date will be calculated from a formula, coupon schedule, or tenor first, then if it falls on a non-business date will be adjusted to the first preceding day that is a business day" ;
	cmns-dsg:hasTag "CSP" ;
	cmns-dsg:hasTextualName "Calculate/Shift preceding" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-NOS
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - NOS" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention for no shift, indicating that there is no date change with respect to the business day" ;
	cmns-dsg:hasTag "NOS" ;
	cmns-dsg:hasTextualName "No Shift" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-SCF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - SCF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a non-business date will be shifted to the first following day that is a business day, follwed by calculating the scheduled date from a formula, coupon schedule, or tenor" ;
	cmns-dsg:hasTag "SCF" ;
	cmns-dsg:hasTextualName "Shift/Calculate following" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-SCMF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - SCMF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a non-business date will be shifted to the first following day that is a business day unless that day falls in the next calendar month, in which case that date will be the first preceding day that is a calendar date, followed by calculating the scheduled date from a formula, coupon schedule, or tenor" ;
	cmns-dsg:hasTag "SCMF" ;
	cmns-dsg:hasTextualName "Shift/Calculate modified following" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-SCMP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - SCMP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a non-business date will be shifted to the first preceding day that is a business day unless that day falls in the prior calendar month, in which case that date will be the first subsequent day that is a calendar date, followed by calculating the scheduled date from a formula, coupon schedule, or tenor" ;
	cmns-dsg:hasTag "SCMP" ;
	cmns-dsg:hasTextualName "Shift/Calculate modified preceding" ;
	.

fibo-actus-act:ACTUSBusinessDayConvention-SCP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSBusinessDayConvention
		;
	rdfs:label "ACTUS business day convention - SCP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "convention that a non-business date will be shifted to the first preceding day that is a business day, follwed by calculating the scheduled date from a formula, coupon schedule, or tenor" ;
	cmns-dsg:hasTag "SCP" ;
	cmns-dsg:hasTextualName "Shift/Calculate preceding" ;
	.

fibo-actus-act:ACTUSCalendarClassifier-MondayToFriday
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSCalendarCode
		;
	rdfs:label "ACTUS calendar code - Monday to Friday" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "calendar code indicating that only week days are considered" ;
	cmns-dsg:hasTag "MondayToFriday" ;
	cmns-dsg:hasTextualName "Monday to Friday calendar" ;
	.

fibo-actus-act:ACTUSCalendarClassifier-NoCalendar
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSCalendarCode
		;
	rdfs:label "ACTUS calendar code - no calendar" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "calendar code indicating that there is no specific calendar, other than the default for the venue/location" ;
	cmns-dsg:hasTag "NoCalendar" ;
	cmns-dsg:hasTextualName "No calendar" ;
	.

fibo-actus-act:ACTUSCalendarCode
	a owl:Class ;
	rdfs:subClassOf
		cmns-cds:CodeElement ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:isDefinedIn ;
			owl:hasValue fibo-actus-act:AlgorithmicContractTypesDataDictionary ;
		]
		;
	rdfs:label "ACTUS calendar code" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "code for a calendar that applies to a particular contract" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier
	a owl:Class ;
	rdfs:subClassOf
		cmns-cls:Classifier ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:isDefinedIn ;
			owl:hasValue fibo-actus-act:AlgorithmicContractTypesDataDictionary ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-cls:classifies ;
			owl:someValuesFrom cmns-rlcmp:Role ;
		]
		;
	rdfs:label "ACTUS contract role classifier" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "classifier for a various roles that are relevant to a particular contract principal" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-BUY
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - BUY" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of BUY, indicating that the legal person identified as the contract principal (creator) plays the role of buyer with respect to the contract" ;
	cmns-dsg:hasTag "BUY" ;
	cmns-dsg:hasTextualName "Buyer" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-CNO
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - CNO" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of CNO, indicating that settlement of the contract involves close-out netting with respect to the legal person identified as the contract principal (creator)" ;
	cmns-dsg:hasTag "CNO" ;
	cmns-dsg:hasTextualName "Close Out Netting" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-COL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - COL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of COL, indicating that the contract is treated as collateral with respect to the legal person identified as the contract principal (creator)" ;
	cmns-dsg:hasTag "COL" ;
	cmns-dsg:hasTextualName "Collateral" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-GUA
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - GUA" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of GUA, indicating that the legal person identified as the contract principal (creator) plays the role of guarantor with respect to the contract" ;
	cmns-dsg:hasTag "GUA" ;
	cmns-dsg:hasTextualName "Guarantor" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-LG
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - LG" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of LG, indicating that the legal person identified as the contract principal (creator) has a long position in the contract" ;
	cmns-dsg:hasTag "LG" ;
	cmns-dsg:hasTextualName "Long Position" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-OBL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - OBL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of OBL, indicating that the legal person identified as the contract principal (creator) plays the role of obligor with respect to the contract" ;
	cmns-dsg:hasTag "OBL" ;
	cmns-dsg:hasTextualName "Obligor" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-PFL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - PFL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of PFL, indicating that the legal person identified as the contract principal (creator) plays the role of payer on the first leg (leg 1) of the contract" ;
	cmns-dsg:hasTag "PFL" ;
	cmns-dsg:hasTextualName "Pay First/Fixed Leg" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-RFL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - RFL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of RFL, indicating that the legal person identified as the contract principal (creator) plays the role of receiver on the first leg (leg 1) of the contract" ;
	cmns-dsg:hasTag "RFL" ;
	cmns-dsg:hasTextualName "Receive First/Fixed Leg" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-RPA
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - RPA" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of RPA, indicating that the contract is considered an asset of the legal person identified as the contract principal (creator)" ;
	cmns-dsg:hasTag "RPA" ;
	cmns-dsg:hasTextualName "Real Position Asset" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-RPL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - RPL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of RPL, indicating that the contract is considered a liability of the legal person identified as the contract principal (creator)" ;
	cmns-dsg:hasTag "RPL" ;
	cmns-dsg:hasTextualName "Real Position Liability" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-SEL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - SEL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of SEL, indicating that the legal person identified as the contract principal (creator) plays the role of seller with respect to the contract" ;
	cmns-dsg:hasTag "SEL" ;
	cmns-dsg:hasTextualName "Seller" ;
	.

fibo-actus-act:ACTUSContractRoleClassifier-ST
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractRoleClassifier
		;
	rdfs:label "ACTUS contract role classifier - ST" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	cmns-dsg:hasDescription "contract role of ST, indicating that the legal person identified as the contract principal (creator) has a short position in the contract" ;
	cmns-dsg:hasTag "ST" ;
	cmns-dsg:hasTextualName "Short Position" ;
	.

fibo-actus-act:ACTUSContractTerm
	a owl:Class ;
	rdfs:subClassOf
		cmns-cds:CodeElement ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-col:isMemberOf ;
			owl:hasValue fibo-actus-act:AlgorithmicContractTypesDataDictionary ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:isDefinedIn ;
			owl:hasValue fibo-actus-act:AlgorithmicContractTypesDataDictionary ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty fibo-actus-act:hasParameterName ;
			owl:onDataRange xsd:string ;
			owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-cls:characterizes ;
			owl:someValuesFrom fibo-actus-acv:ACTUSContractType ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-cls:isClassifiedBy ;
			owl:someValuesFrom fibo-actus-act:ACTUSContractTermGroup ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:hasTag ;
			owl:someValuesFrom xsd:string ;
		] ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:hasTextualName ;
			owl:someValuesFrom xsd:string ;
		]
		;
	rdfs:label "ACTUS contract term" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "code denoting a term describing an aspect of one or more ACTUS contract type(s)" ;
	.

fibo-actus-act:ACTUSContractTerm-AMD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - AMD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "amortizationDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "This Date is used to calculate the annuity amounts for ANN and ANX NGX CT's. Needs only to be set in case where the contract balloon at MD and MD is less than AD." ;
	cmns-dsg:hasTag "AMD" ;
	cmns-dsg:hasTextualName "Amortization Date" ;
	.

fibo-actus-act:ACTUSContractTerm-ARFIXVAR
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - ARFIXVAR" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "arrayFixedVariable" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "For array-type rate reset schedules, this attributes defines the meaning of ARRATE." ;
	cmns-dsg:hasTag "ARRRCL" ;
	cmns-dsg:hasTextualName "Array Fixed Variable" ;
	.

fibo-actus-act:ACTUSContractTerm-ARINCDEC
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - ARINCDEC" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "arrayIncreaseDecrease" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Indicates whether a certain PRNXT element in ARPRNX increases the principal (NT) or decreases it.

Applies only for ANX, NAX, LAX Maturity CTs. For all other Maturity CTs the first principal payment is always in the opposite direction of all other (following) payments.""" ;
	cmns-dsg:hasTag "ARRRCL" ;
	cmns-dsg:hasTextualName "Array Increase Decrease" ;
	.

