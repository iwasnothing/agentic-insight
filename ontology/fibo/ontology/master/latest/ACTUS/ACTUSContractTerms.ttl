	fibo-actus-act:hasParameterName "prepaymentEffect" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "This attribute defines whether or not the right of prepayment exists and if yes, how prepayment affects the remaining principal redemption schedule of the contract" ;
	cmns-dsg:hasTag "PPEF" ;
	cmns-dsg:hasTextualName "Prepayment Effect" ;
	.

fibo-actus-act:ACTUSContractTerm-PPP
	a
		owl:NamedIndividual ,
