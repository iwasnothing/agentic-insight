	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Defines whether the option is a call or put or a combination of it. This field has to be seen in combination with CNTRL where it is defined whether CRID is the buyer or the seller." ;
	cmns-dsg:hasTag "OPTP" ;
	cmns-dsg:hasTextualName "Option Type" ;
	.

fibo-actus-act:ACTUSContractTerm-OPXED
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - OPXED" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "optionExerciseEndDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Final exercise date for American and Bermudan options, expiry date for European options." ;
	cmns-dsg:hasTag "OPXED" ;
	cmns-dsg:hasTextualName "Option Exercise End Date" ;
	.

fibo-actus-act:ACTUSContractTerm-OPXT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - OPXT" ;
