	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "statusDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-ContractIdentification ;
	cmns-dsg:hasDescription "SD holds the date per which all attributes of the record were updated. This is especially important for the highly dynamic attributes like Accruals, Notional, interest rates in variable instruments etc." ;
	cmns-dsg:hasTag "SD" ;
	cmns-dsg:hasTextualName "Status Date" ;
	.

fibo-actus-act:ACTUSContractTerm-SEN
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
