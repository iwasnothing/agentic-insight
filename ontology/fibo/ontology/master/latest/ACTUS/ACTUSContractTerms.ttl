	fibo-actus-act:hasParameterName "nextPrincipalRedemptionPayment" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Amount of principal that will be paid during the redemption cycle at the next payment date. For amortizing contracts like ANN, NAM, ANX, and NAX this is the total periodic payment amount (sum of interest and principal)." ;
	cmns-dsg:hasTag "PRNXT" ;
	cmns-dsg:hasTextualName "Next Principal Redemption Payment" ;
	.

fibo-actus-act:ACTUSContractTerm-PTD
	a
		owl:NamedIndividual ,
