	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "futuresPrice" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Settlement ;
	cmns-dsg:hasDescription "The price the counterparties agreed upon at which the underlying contract (of a FUTUR) is exchanged/settled at STD. Quoting is different for different types of underlyings: Fixed Income = in percentage, all others in nominal terms." ;
	cmns-dsg:hasTag "PFUT" ;
	cmns-dsg:hasTextualName "Futures Price" ;
	.

fibo-actus-act:ACTUSContractTerm-PPEF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
