	fibo-actus-act:hasParameterName "penaltyRate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Either the rate or the absolute amount of the prepayment." ;
	cmns-dsg:hasTag "PYRT" ;
	cmns-dsg:hasTextualName "Penalty Rate" ;
	.

fibo-actus-act:ACTUSContractTerm-PYTP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PYTP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "penaltyType" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Defines whether prepayment is linked to a penalty and of which kind." ;
	cmns-dsg:hasTag "PYTP" ;
	cmns-dsg:hasTextualName "Penalty Type" ;
	.

fibo-actus-act:ACTUSContractTerm-QT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - QT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "quantity" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """This attribute relates either to physical contracts (COM) or underlyings of traded contracts. 

In case of physical contracts it holds the number of underlying units of the specific good (e.g. number of barrels of oil). 

In case of well defined traded contracts it holds the number of defined underlying instruments. Example: QT of STK CTs underlying a FUTUR indicates the number of those specific STK CTs which underlie the FUTUR.""" ;
	cmns-dsg:hasTag "QT" ;
	cmns-dsg:hasTextualName "Quantity" ;
	.

fibo-actus-act:ACTUSContractTerm-RRANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfRateReset" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "Date from which the rate reset date schedule is calculated according to the cycle length. The first rate reset event takes place on this anchor." ;
	cmns-dsg:hasTag "RRANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Rate Reset" ;
	.

fibo-actus-act:ACTUSContractTerm-RRCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfRateReset" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription """Cycle according to which the rate reset date schedule will be calculated.

In case RRCL is not set, then there will only be one rate reset event at RRANX given RRANX if set.

The interval will be adjusted yet by EOMC and BDC.""" ;
	cmns-dsg:hasTag "RRCL" ;
	cmns-dsg:hasTextualName "Cycle Of Rate Reset" ;
	.

fibo-actus-act:ACTUSContractTerm-RRFIX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRFIX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "fixingPeriod" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "Interest rate resets (adjustments) are usually fixed one or two days (usually Business Days) before the new rate applies (defined by the rate reset schedule). This field holds the period between fixing and application of a rate." ;
	cmns-dsg:hasTag "RRFIX" ;
	cmns-dsg:hasTextualName "Fixing Period" ;
	.

fibo-actus-act:ACTUSContractTerm-RRLC
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRLC" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "lifeCap" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription """For variable rate basic CTs this represents a cap on the interest rate that applies during the entire lifetime of the contract.

For CAPFL CTs this represents the cap strike rate.""" ;
	cmns-dsg:hasTag "RRLC" ;
	cmns-dsg:hasTextualName "Life Cap" ;
	.

fibo-actus-act:ACTUSContractTerm-RRLF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRLF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "lifeFloor" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription """For variable rate basic CTs this represents a floor on the interest rate that applies during the entire lifetime of the contract.

For CAPFL CTs this represents the floor strike rate.""" ;
	cmns-dsg:hasTag "RRLF" ;
	cmns-dsg:hasTextualName "Life Floor" ;
	.

fibo-actus-act:ACTUSContractTerm-RRMLT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRMLT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "rateMultiplier" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription """Interest rate multiplier. A typical rate resetting rule is LIBOR plus x basis point where x represents the interest rate spread.

However, in some cases like reverse or super floater contracts an additional rate multiplier applies. In this case, the new rate is determined as: IPNR after rate reset = Rate selected from the market object * RRMLT + RRSP.""" ;
	cmns-dsg:hasTag "RRMLT" ;
	cmns-dsg:hasTextualName "Rate Multiplier" ;
	.

fibo-actus-act:ACTUSContractTerm-RRMO
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRMO" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "marketObjectCodeOfRateReset" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription """Is pointing to the interest rate driver (MarketObject) used for rate reset uniquely.

Unique codes for market objects must be used.""" ;
	cmns-dsg:hasTag "RRMO" ;
	cmns-dsg:hasTextualName "Market Object Code Of Rate Reset" ;
	.

fibo-actus-act:ACTUSContractTerm-RRNXT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRNXT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "nextResetRate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "Holds the new rate that has been fixed already (cf. attribute FixingDays) but not applied. This new rate will be applied at the next rate reset event (after SD and according to the rate reset schedule). Attention, RRNXT must be set to NULL after it is applied!" ;
	cmns-dsg:hasTag "RRNXT" ;
	cmns-dsg:hasTextualName "Next Reset Rate" ;
	.

fibo-actus-act:ACTUSContractTerm-RRPC
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRPC" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "periodCap" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "For variable rate basic CTs this represents the maximum positive rate change per rate reset cycle." ;
	cmns-dsg:hasTag "RRPC" ;
	cmns-dsg:hasTextualName "Period Cap" ;
	.

fibo-actus-act:ACTUSContractTerm-RRPF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRPF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "periodFloor" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "For variable rate basic CTs this represents the maximum negative rate change per rate reset cycle." ;
	cmns-dsg:hasTag "RRPF" ;
	cmns-dsg:hasTextualName "Period Floor" ;
	.

fibo-actus-act:ACTUSContractTerm-RRPNT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRPNT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cyclePointOfRateReset" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription "Normally rates get reset at the beginning of any resetting cycles. There are contracts where the rate is not set at the beginning but at the end of the cycle and then applied to the previous cycle (post-fixing); in other words the rate applies before it is fixed. Hence, the new rate is not known during the entire cycle where it applies. Therefore, the rate will be applied backwards at the end of the cycle. This happens through a correction of interest accrued." ;
	cmns-dsg:hasTag "RRPNT" ;
	cmns-dsg:hasTextualName "Cycle Point Of Rate Reset" ;
	.

fibo-actus-act:ACTUSContractTerm-RRSP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - RRSP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "rateSpread" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-RateReset ;
	cmns-dsg:hasDescription """Interest rate spread. A typical rate resetting rule is LIBOR plus x basis point where x represents the interest rate spread. 

The following equation can be taken if RRMLT is not set: IPNR after rate reset = Rate selected from the market object + RRSP.""" ;
	cmns-dsg:hasTag "RRSP" ;
	cmns-dsg:hasTextualName "Rate Spread" ;
	.

fibo-actus-act:ACTUSContractTerm-SCANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - SCANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfScalingIndex" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Date from which the scaling date schedule is calculated according to the cycle length. The first scaling event takes place on this anchor." ;
	cmns-dsg:hasTag "SCANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Scaling Index" ;
	.

fibo-actus-act:ACTUSContractTerm-SCCDD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - SCCDD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "scalingIndexAtContractDealDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "The value of the Scaling Index as per Contract Deal Date." ;
	cmns-dsg:hasTag "SCCDD" ;
	cmns-dsg:hasTextualName "Scaling Index At Contract Deal Date" ;
	.

fibo-actus-act:ACTUSContractTerm-SCCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - SCCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfScalingIndex" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Cycle according to which the scaling date schedule will be calculated.

In case SCCL is not set, then there will only be one scaling event at SCANX given SCANX is set.

The interval will be adjusted yet by EOMC and BDC.""" ;
	cmns-dsg:hasTag "SCCL" ;
	cmns-dsg:hasTextualName "Cycle Of Scaling Index" ;
	.

