	fibo-actus-act:hasParameterName "priceAtTerminationDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Sellingprice exchanged at PTD PTDrepresents a clean price (includes premium/discount but not IPAC" ;
	cmns-dsg:hasTag "PTD" ;
	cmns-dsg:hasTextualName "Price At Termination Date" ;
