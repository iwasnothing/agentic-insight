	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfFee" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Fees ;
	cmns-dsg:hasDescription "Defines in combination with FEANX the payment points of fees" ;
	cmns-dsg:hasTag "FECL" ;
	cmns-dsg:hasTextualName "Cycle Of Fee" ;
	.

fibo-actus-act:ACTUSContractTerm-FER
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - FER" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "feeRate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Fees ;
	cmns-dsg:hasDescription "Rate of Fee which is a percentage of the underlying or FER is an absolute amount. For all contracts where FEB does not apply (cf. business rules), FER is interpreted as an absolute amount." ;
	cmns-dsg:hasTag "FER" ;
	cmns-dsg:hasTextualName "Fee Rate" ;
	.

fibo-actus-act:ACTUSContractTerm-GRP
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - GRP" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "gracePeriod" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Counterparty ;
	cmns-dsg:hasDescription "If real payment happens after scheduled payment date plus GRP, then the payment is in delay." ;
	cmns-dsg:hasTag "GRP" ;
	cmns-dsg:hasTextualName "Grace Period" ;
	.

fibo-actus-act:ACTUSContractTerm-IED
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IED" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "initialExchangeDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Date of the initial cash flow for Maturity and Non-Maturity CT's. It also coincides with the beginning of interest accrual calculation." ;
	cmns-dsg:hasTag "IED" ;
	cmns-dsg:hasTextualName "Initial Exchange Date" ;
	.

fibo-actus-act:ACTUSContractTerm-IPAC
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPAC" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "accruedInterest" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "Accrued interest as per SD. In case of NULL, this value will be recalculated using IPANX, IPCL and IPNR information. Can be used to represent irregular next IP payments." ;
	cmns-dsg:hasTag "IPAC" ;
	cmns-dsg:hasTextualName "Accrued Interest" ;
	.

fibo-actus-act:ACTUSContractTerm-IPANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfInterestPayment" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "Date from which the interest payment date schedule is calculated according to the cycle length. The first interest payment event takes place on this anchor." ;
	cmns-dsg:hasTag "IPANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Interest Payment" ;
	.

fibo-actus-act:ACTUSContractTerm-IPCB
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPCB" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "interestCalculationBase" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription """This is important for amortizing instruments. The basis of interest calculation is normally the notional outstanding amount as per SD. This is considered the fair basis and in many countries the only legal basis. If NULL or NTSD is selected, this is the case. 

Alternative bases (normally in order to favor the lending institution) are found. In the extreme case the original balance (PCDD=NT+PDCDD) never gets adjusted. In this case PCDD must be chosen. 

An intermediate case exist wherre balances do get adjusted, however with lags. In this case NTL mut be selected and anchor dates and cycles must be set.""" ;
	cmns-dsg:hasTag "IPCB" ;
	cmns-dsg:hasTextualName "Interest Calculation Base" ;
	.

fibo-actus-act:ACTUSContractTerm-IPCBA
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPCBA" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "interestCalculationBaseAmount" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "This is the amount used for the calculation of interest. Calculation base per SD." ;
	cmns-dsg:hasTag "IPCBA" ;
	cmns-dsg:hasTextualName "Interest Calculation Base Amount" ;
	.

fibo-actus-act:ACTUSContractTerm-IPCBANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPCBANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfInterestCalculationBase" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "Date from which the interest calculation base date schedule is calculated according to the cycle length. The first interest calculation base event takes place on this anchor." ;
	cmns-dsg:hasTag "IPCBANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Interest Calculation Base" ;
	.

fibo-actus-act:ACTUSContractTerm-IPCBCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPCBCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfInterestCalculationBase" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription """Concerning the format see PRCL. 

Defines the subsequent adjustment points to NT of the interest payment calculation base.""" ;
	cmns-dsg:hasTag "IPCBCL" ;
	cmns-dsg:hasTextualName "Cycle Of Interest Calculation Base" ;
	.

fibo-actus-act:ACTUSContractTerm-IPCED
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPCED" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "capitalizationEndDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "If IPCED is set, then interest is not paid or received but added to the balance (NT) until IPCED. If IPCED does not coincide with an IP cycle, one additional interest payment gets calculated at IPCED and capitalized. Thereafter normal interest payments occur." ;
	cmns-dsg:hasTag "IPCED" ;
	cmns-dsg:hasTextualName "Capitalization End Date" ;
	.

fibo-actus-act:ACTUSContractTerm-IPCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfInterestPayment" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription """Cycle according to which the interest payment date schedule will be calculated.

In case IPCL is not set, then there will only be an interest payment event at MD (and possibly at IPANX if set).

The interval will be adjusted yet by EOMC and BDC.""" ;
	cmns-dsg:hasTag "IPCL" ;
	cmns-dsg:hasTextualName "Cycle Of Interest Payment" ;
	.

fibo-actus-act:ACTUSContractTerm-IPDC
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPDC" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "dayCountConvention" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "Method defining how days are counted between two dates. This finally defines the year fraction in accrual calculations." ;
	cmns-dsg:hasTag "IPDC" ;
	cmns-dsg:hasTextualName "Day Count Convention" ;
	.

fibo-actus-act:ACTUSContractTerm-IPNR
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPNR" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "nominalInterestRate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription """The nominal interest rate which will be used to calculate accruals and the next interest payment at the next IP date. NT multiplied with IPNR is the base for the interest payment calculation. The relevant time period is a function of IPDC. 

If the contract is variable (RRANX set) this field is periodically updated per SD. 

In the case of plan vanilla interest rate swaps (IRSPV) this defines the rate of fixed leg.""" ;
	cmns-dsg:hasTag "IPNR" ;
	cmns-dsg:hasTextualName "Nominal Interest Rate" ;
	.

fibo-actus-act:ACTUSContractTerm-IPNR2
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPNR2" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "nominalInterestRate2" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription """The nominal interest rate which will be used to calculate accruals and the next interest payment at the next IP date on the second leg (the one not mentioned in CNTRL) of a plain vanilla swap. The relevant time period is a function of IPDC. 

It is periodically updated per SD.""" ;
	cmns-dsg:hasTag "IPNR2" ;
	cmns-dsg:hasTextualName "Nominal Interest Rate 2" ;
	.

fibo-actus-act:ACTUSContractTerm-IPPNT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - IPPNT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cyclePointOfInterestPayment" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Interest ;
	cmns-dsg:hasDescription "Usually, interest is paid at the end of each IPCL which corresponds to a IPPNT value of E which is also the default. If interest payment occurs at the beginning of the cycle, the value is B." ;
	cmns-dsg:hasTag "IPPNT" ;
	cmns-dsg:hasTextualName "Cycle Point Of Interest Payment" ;
	.

fibo-actus-act:ACTUSContractTerm-MD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "maturityDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Marks the contractual end of the lifecycle of a CT. Generally, date of the last cash flows. 

This includes normally a principal and an interest payment. Some Maturity CTs as perpetuals (PBN) do not have such a date. For variable amortizing contracts of the ANN CT, this date might be less than the scheduled end of the contract (which is deduced from the periodic payment amount 

PRNXT). In this case it balloons.""" ;
	cmns-dsg:hasTag "MD" ;
	cmns-dsg:hasTextualName "Maturity Date" ;
	.

fibo-actus-act:ACTUSContractTerm-MOC
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MOC" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "marketObjectCode" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-ContractIdentification ;
	cmns-dsg:hasDescription """Is pointing to the market value at SD (MarketObject).

Unique codes for market objects must be used.""" ;
	cmns-dsg:hasTag "MOC" ;
	cmns-dsg:hasTextualName "Market Object Code" ;
	.

fibo-actus-act:ACTUSContractTerm-MPFD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MPFD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "maximumPenaltyFreeDisbursement" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Defines the notional amount which can be withdrawn before XDN without penalty" ;
	cmns-dsg:hasTag "MPFD" ;
	cmns-dsg:hasTextualName "Maximum Penalty Free Disbursement" ;
	.

fibo-actus-act:ACTUSContractTerm-MRANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfMargining" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription "Date from which the margin call date schedule is calculated according to the cycle length. The first margin call event takes place on this anchor." ;
	cmns-dsg:hasTag "MRANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Margining" ;
	.

fibo-actus-act:ACTUSContractTerm-MRCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfMargining" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription "Defines together with MRANX the points where margins can be called." ;
	cmns-dsg:hasTag "MRCL" ;
	cmns-dsg:hasTextualName "Cycle Of Margining" ;
	.

fibo-actus-act:ACTUSContractTerm-MRCLH
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRCLH" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "clearingHouse" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription "Indicates wheter CRID takes a clearing house function or not. In other word, whether CRID receive margins (MRIM, MRVM)." ;
	cmns-dsg:hasTag "MRCLH" ;
	cmns-dsg:hasTextualName "Clearing House" ;
	.

fibo-actus-act:ACTUSContractTerm-MRIM
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRIM" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "initialMargin" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription """Margin to cover losses which may be incurred as a result of market fluctuations. 

Upon contract closing or maturity, the MRIM is reimbursed.""" ;
	cmns-dsg:hasTag "MRIM" ;
	cmns-dsg:hasTextualName "Initial Margin" ;
	.

fibo-actus-act:ACTUSContractTerm-MRMML
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRMML" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "maintenanceMarginLowerBound" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription "Defines the lower bound of the Maintenance Margin. If MRVM falls below MRMML, then capital must be added to reach the original MRIM." ;
	cmns-dsg:hasTag "MRMML" ;
	cmns-dsg:hasTextualName "Maintenance Margin Lower Bound" ;
	.

fibo-actus-act:ACTUSContractTerm-MRMMU
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRMMU" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "maintenanceMarginUpperBound" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription "Defines the upper bound of the Maintenance Margin. If MRVM falls above MRMMU, then capital is refunded to reach the original MRIM." ;
	cmns-dsg:hasTag "MRMMU" ;
	cmns-dsg:hasTextualName "Maintenance Margin Upper Bound" ;
	.

fibo-actus-act:ACTUSContractTerm-MRVM
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MRVM" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "variationMargin" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Margining ;
	cmns-dsg:hasDescription """MRVM reflects the accrued but not yet paid margin as per SD. 

Open traded positions are revalued by the exchange at the end of every trading day using mark-to-market valuation. Often clearing members do not credit or debit their clients daily with MRVM, but rather use a Maintenance Margin. If the balance falls outside MRMML (and MRMMU), then capital must be added (is refunded) to reach the original margin amount MRIM. We can also say that MVO+MRVM is equal to the reference value as per last margin update.""" ;
	cmns-dsg:hasTag "MRVM" ;
	cmns-dsg:hasTextualName "Variation Margin" ;
	.

fibo-actus-act:ACTUSContractTerm-MVO
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - MVO" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "marketValueObserved" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Value as observed in the market at SD per unit. Incase of fixed income instruments it is a fraction." ;
	cmns-dsg:hasTag "MVO" ;
	cmns-dsg:hasTextualName "Market Value Observed" ;
	.

fibo-actus-act:ACTUSContractTerm-NPD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - NPD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "nonPerformingDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Counterparty ;
	cmns-dsg:hasDescription "The date of the (uncovered) payment event responsible for the current value of the Contract Performance attribute." ;
	cmns-dsg:hasTag "NPD" ;
	cmns-dsg:hasTextualName "Non Performing Date" ;
	.

fibo-actus-act:ACTUSContractTerm-NT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - NT" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "notionalPrincipal" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Current nominal value of the contract. For debt instrument this is the current remaining notional outstanding. 

NT is generally the basis on which interest payments are calculated. If IPCBS is set, IPCBS may introduce a different basis for interest payment calculation.""" ;
	cmns-dsg:hasTag "NT" ;
	cmns-dsg:hasTextualName "Notional Principal" ;
	.

fibo-actus-act:ACTUSContractTerm-NT2
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - NT2" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "notionalPrincipal2" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Notional amount of the second currency to be exchanged in an FXOUT CT." ;
	cmns-dsg:hasTag "NT2" ;
	cmns-dsg:hasTextualName "Notional Principal 2" ;
	.

fibo-actus-act:ACTUSContractTerm-OPANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - OPANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfOptionality" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription """Used for Basic Maturities (such as PAM, RGM, ANN, NGM and their Step-up versions) and American and Bermudan style options. 

- Basic Maturities: Within the group of these Maturities, it indicates the possibility of prepayments. Prepayment features are controlled by Behavior. 

- American and Bermudan style Options: Begin of exercise period.""" ;
	cmns-dsg:hasTag "OPANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Optionality" ;
	.

fibo-actus-act:ACTUSContractTerm-OPCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - OPCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfOptionality" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription """Cycle according to which the option exercise date schedule will be calculated.

OPCL can be NULL for American Options or Prepayment Optionality in which case the optionality period starts at OPANX and ends at OPXED (for american options) or MD (in case of prepayment optionality).

The interval will be adjusted yet by EOMC and BDC.""" ;
	cmns-dsg:hasTag "OPCL" ;
	cmns-dsg:hasTextualName "Cycle Of Optionality" ;
	.

fibo-actus-act:ACTUSContractTerm-OPS1
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - OPS1" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "optionStrike1" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription """Strike price of the option. Whether it is a call/put is determined by the attribute OPTP, i.e a call or a put (or a combination of call/put).

This attribute is used for price related options such as options on bonds, stocks or FX. Interest rate related options (caps/floos) are handled within th RatReset group.""" ;
	cmns-dsg:hasTag "OPS1" ;
	cmns-dsg:hasTextualName "Option Strike 1" ;
	.

fibo-actus-act:ACTUSContractTerm-OPS2
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - OPS2" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "optionStrike2" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Put price in case of call/put." ;
	cmns-dsg:hasTag "OPS2" ;
	cmns-dsg:hasTextualName "Option Strike 2" ;
	.

fibo-actus-act:ACTUSContractTerm-OPTP
	a
		owl:NamedIndividual ,
