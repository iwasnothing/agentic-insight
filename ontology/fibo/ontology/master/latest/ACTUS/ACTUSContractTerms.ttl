@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/>
	a owl:Ontology ;
	rdfs:label "ACTUS Contract Terms" ;
	dcterms:abstract "This ontology represents the ACTUS contract terms that comprise the ACTUS data dictionary as a controlled vocabulary and maps it to FIBO, providing the corresponding semantics and enabling integration of knowledge graphs based on FIBO with the ACTUS system." ;
