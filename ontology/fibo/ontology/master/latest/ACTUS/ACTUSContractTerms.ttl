	fibo-actus-act:hasParameterName "creditLineAmount" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """If defined, gives the total amount that can be drawn from a credit line. The remaining amount that can still be drawn is given by CLA-NT.

For ANN, NAM, the credit line can only be drawn prior to PRANX-1PRCL.

For CRL, the remaining amount that can still be drawn is given by CLA-Sum(NT of attached contracts).""" ;
	cmns-dsg:hasTag "CLA" ;
	cmns-dsg:hasTextualName "Credit Line Amount" ;
	.

fibo-actus-act:ACTUSContractTerm-CLDR
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
