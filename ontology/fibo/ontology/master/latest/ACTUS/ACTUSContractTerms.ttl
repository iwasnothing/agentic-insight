	fibo-actus-act:hasParameterName "priceAtPurchaseDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Purchase price exchanged at PRD. 

PPRD represents a clean price (includes premium/discount but not IPAC).""" ;
	cmns-dsg:hasTag "PPRD" ;
	cmns-dsg:hasTextualName "Price At Purchase Date" ;
	.

fibo-actus-act:ACTUSContractTerm-PRANX
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PRANX" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleAnchorDateOfPrincipalRedemption" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Date from which the principal payment date schedule is calculated according to the cycle length. The first principal payment event takes place on this anchor." ;
	cmns-dsg:hasTag "PRANX" ;
	cmns-dsg:hasTextualName "Cycle Anchor Date Of Principal Redemption" ;
	.

fibo-actus-act:ACTUSContractTerm-PRCL
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PRCL" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "cycleOfPrincipalRedemption" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Cycle according to which the interest payment date schedule will be calculated.

In case PRCL is not set, then there will only be one principal payment event at MD (and possibly at PRANX if set).

The interval will be adjusted yet by EOMC and BDC.""" ;
	cmns-dsg:hasTag "PRCL" ;
	cmns-dsg:hasTextualName "Cycle Of Principal Redemption" ;
	.

fibo-actus-act:ACTUSContractTerm-PRD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PRD" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "purchaseDate" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """If a contract is bought after initiation (for example a bond on the secondary market) this date has to be set. It refers to the date at which the payment (of PPRD) and transfer of the security happens. In other words, PRD - if set - takes the role otherwise IED has from a cash flow perspective. 

Note, CPID of the CT is not the counterparty of the transaction!""" ;
	cmns-dsg:hasTag "PRD" ;
	cmns-dsg:hasTextualName "Purchase Date" ;
	.

fibo-actus-act:ACTUSContractTerm-PRF
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PRF" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "contractPerformance" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Counterparty ;
	cmns-dsg:hasDescription "Indicates the current contract performance status. Different states of the contract range from performing to default." ;
	cmns-dsg:hasTag "PRF" ;
	cmns-dsg:hasTextualName "Contract Performance" ;
	.

fibo-actus-act:ACTUSContractTerm-PRNXT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PRNXT" ;
