	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Boundary ;
	cmns-dsg:hasDescription "Boundary direction specifies the direction of motion in the underlying asset's price which will be considered a valid crossing of the boundary and trigger the boundary effect changing which, if any, of the boundary legs is active." ;
	cmns-dsg:hasTag "BDR" ;
	cmns-dsg:hasTextualName "Boundary Direction" ;
	.

