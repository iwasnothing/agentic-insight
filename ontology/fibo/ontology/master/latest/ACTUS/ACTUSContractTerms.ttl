	fibo-actus-act:hasParameterName "optionExerciseType" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Optionality ;
	cmns-dsg:hasDescription "Defines whether the option is European (exercised at a specific date), American (exercised during a span of time) or Bermudan (exercised at certain points during a span of time)." ;
	cmns-dsg:hasTag "OPXT" ;
	cmns-dsg:hasTextualName "Option Exercise Type" ;
	.

fibo-actus-act:ACTUSContractTerm-PDIED
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
	rdfs:label "ACTUS dictionary term - PDIED" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	fibo-actus-act:hasParameterName "premiumDiscountAtIED" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription """Total original premium or discount that has been set at CDD and will be added to the (notional) cash flow at IED (cash flow at IED = NT+PDIED, w.r.t. an RPA CT). 

Negative value for discount and positive for premium.

Note, similar to interest the PDIED portion is part of P&L.""" ;
	cmns-dsg:hasTag "PDIED" ;
	cmns-dsg:hasTextualName "Premium Discount At IED" ;
	.

fibo-actus-act:ACTUSContractTerm-PFUT
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
