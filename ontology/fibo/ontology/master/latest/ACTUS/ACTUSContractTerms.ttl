	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-NotionalPrincipal ;
	cmns-dsg:hasDescription "Indicates which payments are scaled. I = Interest payments, N = Nominal payments and M = Maximum deferred interest amount. They can be scaled in any combination." ;
	cmns-dsg:hasTag "SCEF" ;
	cmns-dsg:hasTextualName "Scaling Effect" ;
