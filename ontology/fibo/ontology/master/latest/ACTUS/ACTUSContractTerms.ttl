fibo-actus-act:AlgorithmicContractTypesDataDictionary
	a
		owl:NamedIndividual ,
		cmns-cds:CodeSet ,
		[
			a owl:Restriction ;
			owl:onProperty cmns-dsg:defines ;
			owl:someValuesFrom fibo-actus-act:ACTUSContractTerm ;
		]
		;
	rdfs:label "Algorithmic Contract Types data dictionary" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "system of alpha-numeric symbols, or combinations of symbols, that stand for the terms in the ACTUS data dictionary, a controlled vocabulary defining the parameters that may apply to any given contract type" ;
	cmns-av:abbreviation "ACTUS data dictionary" ;
	cmns-av:adaptedFrom "https://www.actusfrf.org/methodology"^^xsd:anyURI ;
	.

fibo-actus-act:hasOptionSequenceNumber
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf cmns-qtu:hasNumericValue ;
	rdfs:label "has option sequence number" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	rdfs:range xsd:nonNegativeInteger ;
	skos:definition "specifies the order of occurance of an optional element in an enumerated list" ;
	.

fibo-actus-act:hasParameterMapping
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf cmns-txt:hasTextValue ;
	rdfs:label "has parameter mapping" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "maps a quantitative or qualitative parameter defined in the ACTUS data dictionary with something else, such as a property specified in FIBO" ;
	.

fibo-actus-act:hasParameterName
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf cmns-dsg:hasTextualName ;
	rdfs:label "has parameter name" ;
	rdfs:isDefinedBy <https://spec.edmcouncil.org/fibo/ontology/ACTUS/ACTUSContractTerms/> ;
	skos:definition "associates a name with a quantitative or qualitative factor defined in the ACTUS data dictionary used as a condition for classification of one or more contract type" ;
	.

