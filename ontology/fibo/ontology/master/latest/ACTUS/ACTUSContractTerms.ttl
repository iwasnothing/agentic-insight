	fibo-actus-act:hasParameterName "prepaymentPeriod" ;
	cmns-cls:isClassifiedBy fibo-actus-act:ACTUSContractTermGroup-Counterparty ;
	cmns-dsg:hasDescription "If real payment happens before scheduled payment date minus PPP, then it is considered a prepayment. Effect of prepayments are further described in PPEF and related fields." ;
	cmns-dsg:hasTag "PPP" ;
	cmns-dsg:hasTextualName "Prepayment Period" ;
	.

fibo-actus-act:ACTUSContractTerm-PPRD
	a
		owl:NamedIndividual ,
		fibo-actus-act:ACTUSContractTerm
		;
